+                password: pass_entry.text,
+                character: normalized_character,
+                game_code: selected_iter[0]
+              )
+
+              launch_data = Authentication.prepare_launch_data(
+                launch_data_hash,
+                frontend,
+                custom_launch,
+                custom_launch_dir
+              )
+              # Prep login data
